# Supabase (get these from your Supabase project settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key-here

# Server-only key (never expose to browser). Get from Supabase → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Optional for local Supabase CLI dev
# SUPABASE_URL=http://127.0.0.1:54321
# SUPABASE_ANON_KEY=...

# Your deployed site URL (update after deploying to Vercel etc.)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
